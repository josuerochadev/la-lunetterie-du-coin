#!/usr/bin/env sh
# . "$(dirname "$0")/_/husky.sh" # DEPRECATED in Husky v10

echo "🔍 Running pre-commit checks..."

# Type checking (fast)
echo "📝 Checking TypeScript types..."
pnpm run typecheck || exit 1

# Lint and format staged files only (much faster)
echo "🧹 Linting and formatting staged files..."
pnpm exec lint-staged --allow-empty || exit 1

# Run tests related to changed files only
echo "🧪 Running related tests..."
pnpm exec vitest run --changed --passWithNoTests || exit 1

echo "✅ Pre-commit checks passed!"
