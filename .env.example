# === Development Environment Variables Example ===
# Copy to .env.local for development or .env.production for production
# NEVER commit actual environment variables to Git!

# =============================================
# REQUIRED — le projet ne démarre pas sans ces valeurs
# =============================================

# === Core Application Configuration ===
NODE_ENV=development
VITE_APP_ENV=development
# Set to "true" to show the real site, "false" for coming soon page
VITE_SITE_LIVE=true

# === Development URLs ===
VITE_PUBLIC_URL=http://localhost:5173

# =============================================
# OPTIONAL — fonctionnalités dégradées sans ces valeurs
# =============================================

# === Sentry Error Monitoring ===
VITE_SENTRY_DSN=https://your-dsn@sentry.io/project-id
VITE_SENTRY_AUTH_TOKEN=your-auth-token
VITE_SENTRY_ORG=your-org
VITE_SENTRY_PROJECT=your-project
VITE_SENTRY_ENVIRONMENT=development

# === Analytics (Plausible recommandé — léger & respectueux vie privée) ===
VITE_ANALYTICS_DOMAIN=la-lunetterie-du-coin.fr
# Alternative: Google Analytics 4
# VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# === External Integrations ===
# Formspree — fonctionnalité formulaire de contact
VITE_FORMSPREE_ENDPOINT=https://formspree.io/f/your-form-id

# === Build & Deployment Info (auto-remplis au build) ===
VITE_BUILD_TIME=
VITE_COMMIT_HASH=
VITE_VERSION=1.0.0

# === URLs supplémentaires ===
VITE_API_BASE_URL=http://localhost:3001

# === Health Check & Monitoring (scripts uniquement) ===
ALERT_EMAIL=developer@example.com
ALERT_WEBHOOK=
MONITORING_INTERVAL=60000